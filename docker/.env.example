# =============================================================================
# Environment Variables — AI Dev Workspace Stack
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit the filled .env to version control!
# =============================================================================

# ---------------------------------------------------------------------------
# General Stack Configuration
# ---------------------------------------------------------------------------
NODE_ENV=production
TAG=latest
REGISTRY=local

# ---------------------------------------------------------------------------
# Port Configuration
# ---------------------------------------------------------------------------
# OmniRoute AI Gateway
OMNIROUTE_PORT=4000

# Hermes Workspace UI
HERMES_PORT=3000

# Aion UI
AIONUI_PORT=3005

# Optionally expose hermes-agent gateway externally
# (uncomment the port in docker-compose.yaml too)
# HERMES_GATEWAY_PORT=8642

# ---------------------------------------------------------------------------
# LLM Provider Keys
# ---------------------------------------------------------------------------
# Add at least ONE provider key. hermes-agent uses whichever provider
# you configure via `hermes setup` or `hermes model` inside the container.
# OmniRoute and Aion UI also use these keys.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
MISTRAL_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
DEEPSEEK_API_KEY=
TOGETHER_API_KEY=

# ---------------------------------------------------------------------------
# hermes-agent — Gateway API Server Auth Key
# ---------------------------------------------------------------------------
# Shared secret between the hermes-agent gateway and hermes-workspace.
# The entrypoint.sh configures the gateway with this key automatically.
# hermes-workspace connects using this same key (set via supervisord.conf).
#
# Generate with: openssl rand -hex 32
# Leave EMPTY only if you don't need auth (single-user, private network).
API_SERVER_KEY=

# LLM model to be used by hermes-agent (e.g. gpt-4o, claude-3-5-sonnet, etc.)
# If left empty, hermes-agent will ask or use its default.
HERMES_LLM_MODEL=

# ---------------------------------------------------------------------------
# Hermes Workspace Configuration
# ---------------------------------------------------------------------------
# NOTE: HERMES_API_URL and HERMES_DASHBOARD_URL are set to localhost
# automatically inside supervisord.conf — no need to set them here.

# Secret key for cookie/session signing (any long random string)
HERMES_SECRET_KEY=

# Session secret (different from HERMES_SECRET_KEY)
HERMES_SESSION_SECRET=change-me-in-production

# Password to access the Hermes Workspace UI
# Required when the container is exposed to the internet
HERMES_PASSWORD=

# Set to 1 ONLY if you want to bypass the password check (insecure!)
HERMES_ALLOW_INSECURE_REMOTE=0

# Set to 0 when not using HTTPS (prevents login loops over plain http)
COOKIE_SECURE=0

# ---------------------------------------------------------------------------
# OmniRoute Configuration
# ---------------------------------------------------------------------------
OMNIROUTE_DEFAULT_PROVIDER=openai
OMNIROUTE_LOG_LEVEL=info
OMNIROUTE_RATE_LIMIT=100
OMNIROUTE_ENABLE_CACHE=true

# ---------------------------------------------------------------------------
# Aion UI Configuration
# ---------------------------------------------------------------------------
AION_API_URL=http://localhost:4000
AION_HERMES_URL=http://localhost:3000
AION_SECRET_KEY=

# ---------------------------------------------------------------------------
# Claude Code CLI Configuration
# ---------------------------------------------------------------------------
CLAUDE_CODE_API_KEY=
CLAUDE_CODE_MODEL=claude-sonnet-4-20250514

# ---------------------------------------------------------------------------
# Antigravity CLI Configuration
# ---------------------------------------------------------------------------
ANTIGRAVITY_API_KEY=
GOOGLE_CLOUD_PROJECT=

# ---------------------------------------------------------------------------
# OpenCode CLI Configuration
# ---------------------------------------------------------------------------
OPENCODE_PROVIDER=anthropic
OPENCODE_API_KEY=

# ---------------------------------------------------------------------------
# CommandCode CLI Configuration
# ---------------------------------------------------------------------------
COMMANDCODE_AUTH_TOKEN=
