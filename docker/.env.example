# =============================================================================
# Environment Variables — AI Dev Workspace Stack
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit the filled .env to version control!
# =============================================================================

# ---------------------------------------------------------------------------
# General Stack Configuration
# ---------------------------------------------------------------------------
NODE_ENV=production
TAG=latest
REGISTRY=local

# ---------------------------------------------------------------------------
# Port Configuration
# ---------------------------------------------------------------------------
# OmniRoute default port
OMNIROUTE_PORT=4000

# Hermes Workspace default port
HERMES_PORT=3000

# Aion UI — remapped to 3005 (internal stays 3000)
AIONUI_PORT=3005

# ---------------------------------------------------------------------------
# OmniRoute Configuration
# ---------------------------------------------------------------------------
# API keys for AI providers (add as many as needed)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
MISTRAL_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
DEEPSEEK_API_KEY=
TOGETHER_API_KEY=

# OmniRoute-specific settings
OMNIROUTE_DEFAULT_PROVIDER=openai
OMNIROUTE_LOG_LEVEL=info
OMNIROUTE_RATE_LIMIT=100
OMNIROUTE_ENABLE_CACHE=true

# ---------------------------------------------------------------------------
# Hermes Workspace Configuration
# ---------------------------------------------------------------------------
HERMES_API_URL=http://localhost:4000
HERMES_SECRET_KEY=
HERMES_SESSION_SECRET=change-me-in-production
# Password required when HOST=0.0.0.0 (non-localhost) to prevent unauthorized access.
HERMES_PASSWORD=
# Set to 1 only if you want to bypass the password requirement (insecure!).
HERMES_ALLOW_INSECURE_REMOTE=0
# Set to 0 when deploying over plain http (non-https) to prevent login loops.
COOKIE_SECURE=0

# ---------------------------------------------------------------------------
# Aion UI Configuration
# ---------------------------------------------------------------------------
AION_API_URL=http://localhost:4000
AION_HERMES_URL=http://localhost:3000
AION_SECRET_KEY=

# ---------------------------------------------------------------------------
# Claude Code CLI Configuration
# ---------------------------------------------------------------------------
CLAUDE_CODE_API_KEY=
CLAUDE_CODE_MODEL=claude-sonnet-4-20250514

# ---------------------------------------------------------------------------
# Antigravity CLI Configuration
# ---------------------------------------------------------------------------
ANTIGRAVITY_API_KEY=
GOOGLE_CLOUD_PROJECT=

# ---------------------------------------------------------------------------
# OpenCode CLI Configuration
# ---------------------------------------------------------------------------
OPENCODE_PROVIDER=anthropic
OPENCODE_API_KEY=

# ---------------------------------------------------------------------------
# CommandCode CLI Configuration
# ---------------------------------------------------------------------------
COMMANDCODE_AUTH_TOKEN=
